<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Data Table</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 40px;
            background-color: #f4f7f6;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background-color: #ffffff;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            border-radius: 8px;
            overflow: hidden;
        }

        th {
            background-color: #2c3e50;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 15px;
            text-align: left;
        }

        td {
            padding: 12px 15px;
            border-bottom: 1px solid #ddd;
            color: #333;
        }

        tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        tr:hover {
            background-color: #f1f1f1;
        }
    </style>
</head>
<body>

    <table>
        <thead>
            <tr>
                <th>URL</th>
                <th>Short Code</th>
                <th>Created At</th>
                <th>Updated At</th>
                <th>Access Count</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><%= url %></td>
                <td><%= shortCode %></td>
                <td><%= createdAt %></td>
                <td><%= updatedAt %></td>
                <td><%= accessCount %></td>
            </tr>
        </tbody>
    </table>

</body>
</html>