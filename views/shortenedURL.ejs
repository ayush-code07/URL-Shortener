<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shortened URL</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .container {
            background-color: white;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            text-align: center;
            width: 100%;
            max-width: 450px;
        }

        h1 { color: #333; margin-top: 0; }
        .short-url-box {
            background: #e9ecef;
            padding: 10px;
            border-radius: 6px;
            margin: 15px 0;
            font-weight: bold;
        }

        input {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 6px;
            box-sizing: border-box;
        }

        button {
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            transition: opacity 0.3s;
            margin: 5px;
        }

        .btn-update { background-color: #007bff; color: white; width: 100%; }
        .btn-delete { background-color: #dc3545; color: white; margin-top: 20px; }
        button:hover { opacity: 0.8; }
    </style>
</head>

<body>
    <div class="container">
        <h1>URL Ready!</h1>
        <p>Your shortened link:</p>
        <div class="short-url-box">
            <a href="/shorten/<%= shortCode %>" target="_blank">
                <%= fullUrl %>
            </a>
        </div>

        <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

        <div>
            <h2>Update URL</h2>
            <input id="updateURL" type="text" placeholder="Enter the new long URL">
            <button class="btn-update" onclick="updateShortURL('<%= shortCode %>', document.getElementById('updateURL').value)">
                Update Destination
            </button>
        </div>

        <div>
            <button class="btn-delete" onclick="deleteShortURL('<%= shortCode %>')">Delete this Link</button>
        </div>

        <div>
            <button class="btn-stats" onclick="window.location.href='/shorten/<%= shortCode %>/stats'">Get Stats</button>
        </div>
    </div>

    <script>
        async function updateShortURL(shortCode, newUrl) {
            try {
                const response = await fetch(`/shorten/${shortCode}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ newURL: newUrl })
                });

                if (response.ok) {
                    alert('URL updated successfully!');
                } else {
                    alert('Failed to update URL');
                }
            } catch (error) {
                console.error('Network error:', error);
            }
        }

        async function deleteShortURL(shortCode) {
            if (!confirm('Are you sure you want to delete this link?')) return;
            
            try {
                const response = await fetch(`/shorten/${shortCode}`, { method: 'DELETE' });

                if (response.status === 204) {
                    alert('URL deleted successfully!');
                    window.location.href = '/';
                } else {
                    alert('Error deleting URL');
                }
            } catch (error) {
                console.error('Network error:', error);
            }
        }
    </script>
</body>
</html>